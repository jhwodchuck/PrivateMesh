# PrivateMesh — Root Environment Configuration
# Copy to .env and fill in values before running Docker Compose.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://privatemesh:privatemesh@localhost:5432/privatemesh
DB_PASSWORD=privatemesh

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Object storage (MinIO for local dev) ────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=privatemesh
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Session / auth (REQUIRED — generate with: openssl rand -hex 32) ─────────
SESSION_SECRET=change-me-32-bytes-minimum-secret

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3002
CORS_ORIGIN=http://localhost:3000

# ── Observability ────────────────────────────────────────────────────────────
RUST_LOG=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Email (magic-link auth — Sprint 1) ──────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@privatemesh.local
